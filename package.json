{
  "name": "obsidian-mindline",
  "version": "0.3.0",
  "description": "A Mubu-style Markdown outline mind map plugin for Obsidian.",
  "main": "main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch"
  },
  "dependencies": {
    "mdast-util-from-markdown": "^2.0.0",
    "nanoid": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "obsidian": "^1.0.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
